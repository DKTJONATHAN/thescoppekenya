{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/article/2026-04-24-airtel-kenya-earn-ksh100-per-referral-on-myairtel-app",
      "destination": "/article/2026-04-25-airtel-kenya-launches-ksh100-refer-and-earn-on-myairtel-app",
      "permanent": true
    },
    {
      "source": "/article/2026-04-29-george-clooney-reacts-to-his-lake-como-villa-appearing-in-the-devil-",
      "destination": "/article/2026-05-04-director-explains-devil-wears-prada-2-death-scene-twist",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(sitemap[^/]*\\.xml)",
      "destination": "/$1"
    },
    {
      "source": "/rss.xml",
      "destination": "/feed.xml"
    },
    {
      "source": "/feed.xml",
      "destination": "/feed.xml"
    },
    {
      "source": "/llms.txt",
      "destination": "/llms.txt"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap",
      "destination": "/index"
    },
    {
      "source": "/search",
      "destination": "/index"
    },
    {
      "source": "/news",
      "destination": "/index"
    },
    {
      "source": "/entertainment",
      "destination": "/index"
    },
    {
      "source": "/sports",
      "destination": "/index"
    },
    {
      "source": "/business",
      "destination": "/index"
    },
    {
      "source": "/lifestyle",
      "destination": "/index"
    },
    {
      "source": "/trending",
      "destination": "/index"
    },
    {
      "source": "/article/:slug",
      "destination": "/article/:slug/index.html"
    },
    {
      "source": "/category/:slug",
      "destination": "/category/:slug/index.html"
    },
    {
      "source": "/:path((?!article/|category/).*)",
      "destination": "/index"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/(sitemap[^/]*\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/(rss\\.xml|llms\\.txt|robots\\.txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
